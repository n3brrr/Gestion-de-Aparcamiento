<div class="row justify-content-center">
    <div class="col-md-10">
        <h2 class="mb-4">Historial de Aparcamientos</h2>

        <div class="card shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle" id="tabla-historial">
                        <thead class="table-dark">
                            <tr>
                                <th>Aparcado el</th>
                                <th>Recogido el</th>
                                <th>Ubicación</th>
                            </tr>
                        </thead>
                        <tbody id="historial-body">
                        </tbody>
                    </table>
                </div>

                <div id="no-data" class="alert alert-warning d-none text-center mb-0">
                    Aún no tienes aparcamientos registrados en el historial local de este dispositivo.
                </div>
            </div>
        </div>

    </div>
</div>

<script src="/javascripts/historial.js"></script>