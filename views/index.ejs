<div class="row justify-content-center">
  <div class="col-12">

    <div class="card shadow-sm mb-4">
      <div class="card-body text-center">
        <h2 class="h4 mb-3">Estado de tu vehículo</h2>

        <div id="info-panel" class="d-none alert alert-info">
          <p class="mb-1"><strong>Distancia:</strong> <span id="distancia">Calculando...</span> metros</p>
          <p class="mb-0"><strong>Tiempo aparcado:</strong> <span id="tiempo">0</span> minutos</p>
        </div>

        <div class="row g-2">
            <div class="col-md-6 mx-auto">
                <button id="btn-aparcar" class="btn btn-primary btn-lg w-100">
                  He aparcado aquí
                </button>
                <button id="btn-retirar" class="btn btn-success btn-lg w-100 d-none">
                  Ya he recogido el coche
                </button>
            </div>
        </div>
      </div>
    </div>

    <div class="card shadow-sm">
      <div class="card-body p-0">
        <div id="map" style="height: 750px; width: 100%; border-radius: 0.375rem;"></div>
      </div>
      <div class="card-footer text-muted small text-center">
        Puedes pulsar en el mapa para ajustar la posición exacta de tu vehículo
      </div>
    </div>

  </div>
</div>